# Supabase (Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
# Use service_role secret for backend API (bypasses RLS), OR run sql/rls_policies.sql with anon key
SUPABASE_KEY=your-service-role-secret

# OpenRouter (OpenAI-compatible)
OPENAI_API_KEY=sk-or-v1-your-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini

# JWT (required) — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_MINUTES=30

# Comma-separated frontend origins (use * only for local/dev)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# When true, outline/chapters pause at pending_review for human approval
REQUIRE_HUMAN_REVIEW=true

# Optional integrations
# SLACK_WEBHOOK_URL=
# CICD_WEBHOOK_URL=

# Docker: copy to .env, then run: docker compose up --build
# API is published on host port 8001 → container 8000
